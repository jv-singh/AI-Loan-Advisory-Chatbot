# ──────────────────────────────────────────────────────────────────────────────
# Loan Advisory Agent — Environment Configuration
# Copy this to .env and fill in your values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini                # gpt-4o for production
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_KEY=eyJ...your-service-key...  # for server-side ops

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/loan_agent

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development                     # development | production
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ── RAG Settings ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db    # local vector DB path
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.35

# ── Agent Behaviour ───────────────────────────────────────────────────────────
MAX_ITERATIONS=10
TEMPERATURE=0.1                         # low temp = more factual
HALLUCINATION_THRESHOLD=0.5            # confidence below this → flag response

# ── Frontend ──────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
