# ──────────────────────────────────────────────────────────────────────────────
# Loan Advisory Agent — Environment Configuration
# Copy this to .env and fill in your values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Default is Groq (free tier). Set to "openai" if you want to use OpenAI.
LLM_PROVIDER=groq

# ── Groq (free tier) ──────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...your-key-here...
GROQ_MODEL=llama-3.1-8b-instant          # free tier; alternatives: llama-3.3-70b-versatile, mixtral-8x7b-32768

# ── OpenAI (only used when LLM_PROVIDER=openai) ──────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini                # gpt-4o for production

# ── Embeddings (local & free by default — no API key required) ────────────────
# Groq does not host embeddings, so we default to a local sentence-transformer.
# Set EMBEDDING_PROVIDER=openai if you want to use OpenAI embeddings.
EMBEDDING_PROVIDER=huggingface
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_KEY=eyJ...your-service-key...  # for server-side ops

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/loan_agent

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development                     # development | production
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ── RAG Settings ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db    # local vector DB path
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.35

# ── Agent Behaviour ───────────────────────────────────────────────────────────
MAX_ITERATIONS=10
TEMPERATURE=0.1                         # low temp = more factual
HALLUCINATION_THRESHOLD=0.5            # confidence below this → flag response

# ── Frontend ──────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
